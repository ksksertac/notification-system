# Redis (primary data store + queue)
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue
QUEUE_CONSUMER_GROUP=notification-workers
QUEUE_WEIGHT_HIGH=10
QUEUE_WEIGHT_NORMAL=5
QUEUE_WEIGHT_LOW=2
QUEUE_WORKER_COUNT=5
QUEUE_CLAIM_MIN_IDLE=30s
QUEUE_CLAIM_INTERVAL=15s

# Rate Limiter
RATE_LIMIT_PER_SECOND=100

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_OPEN_DURATION=30s
CB_HALF_OPEN_MAX_REQUESTS=1

# Retry
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY=2s
RETRY_MAX_DELAY=60s

# Provider (type: "webhook" or "mock")
PROVIDER_TYPE=mock
WEBHOOK_URL=https://webhook.site/7e684354-ab49-461e-b9d9-531adf3ce458
PROVIDER_TIMEOUT=10s
PROVIDER_MOCK_LATENCY=50ms

# Logging
LOG_LEVEL=info

# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=30s

# Redis (primary data store + queue)
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL (read-only fallback for cold data)
DB_HOST=pgbouncer
DB_PORT=5432
DB_USER=notification
DB_PASSWORD=notification_secret
DB_NAME=notification_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME=5m

# Queue
QUEUE_CONSUMER_GROUP=notification-workers
QUEUE_WEIGHT_HIGH=10
QUEUE_WEIGHT_NORMAL=5
QUEUE_WEIGHT_LOW=2

# Rate Limiter
RATE_LIMIT_PER_SECOND=100

# Retry
RETRY_MAX_ATTEMPTS=5

# Provider
WEBHOOK_URL=https://webhook.site/7e684354-ab49-461e-b9d9-531adf3ce458

# Authentication
API_KEY=changeme-notification-secret

# Logging
LOG_LEVEL=info

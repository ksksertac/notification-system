# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=notification
DB_PASSWORD=notification_secret
DB_NAME=notification_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue (not used by dbwriter, but required by config)
QUEUE_CONSUMER_GROUP=notification-workers

# Provider (not used by dbwriter, but required by config)
WEBHOOK_URL=https://webhook.site/7e684354-ab49-461e-b9d9-531adf3ce458

# Logging
LOG_LEVEL=info

{
  "title": "Notification Pipeline",
  "uid": "notification-pipeline",
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "channel",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(notifications_delivered_total, channel)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "title": "Pipeline Overview",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "title": "Delivered / sec",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(notifications_delivered_total{channel=~\"$channel\"}[1m]))",
          "legendFormat": "delivered/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "title": "Failed / sec",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(notifications_failed_total{channel=~\"$channel\"}[1m]))",
          "legendFormat": "failed/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "title": "Failure Rate %",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(notifications_failed_total{channel=~\"$channel\"}[1m])) / (sum(rate(notifications_delivered_total{channel=~\"$channel\"}[1m])) + sum(rate(notifications_failed_total{channel=~\"$channel\"}[1m]))) * 100",
          "legendFormat": "failure %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 5,
                "color": "yellow"
              },
              {
                "value": 20,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "title": "P95 Delivery Latency",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(notification_delivery_duration_seconds_bucket{channel=~\"$channel\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "title": "Rate Limit Hits",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(rate_limit_hits_total[1m]))",
          "legendFormat": "hits/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 10,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "title": "Circuit Breaker Opens",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(circuit_breaker_open_total[1m]))",
          "legendFormat": "opens/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 0.01,
                "color": "yellow"
              },
              {
                "value": 0.1,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "title": "Queue & Throughput",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "title": "Queue Depth by Priority",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "queue_depth",
          "legendFormat": "{{stream}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "high"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "normal"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "low"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Deliveries vs Failures / sec by Channel",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(notifications_delivered_total{channel=~\"$channel\"}[1m])",
          "legendFormat": "delivered \u2014 {{channel}}"
        },
        {
          "expr": "rate(notifications_failed_total{channel=~\"$channel\"}[1m])",
          "legendFormat": "failed \u2014 {{channel}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "Delivery Latency",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false
    },
    {
      "title": "Latency Percentiles by Channel",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(notification_delivery_duration_seconds_bucket{channel=~\"$channel\"}[5m])) by (le, channel))",
          "legendFormat": "p50 \u2014 {{channel}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(notification_delivery_duration_seconds_bucket{channel=~\"$channel\"}[5m])) by (le, channel))",
          "legendFormat": "p95 \u2014 {{channel}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(notification_delivery_duration_seconds_bucket{channel=~\"$channel\"}[5m])) by (le, channel))",
          "legendFormat": "p99 \u2014 {{channel}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "Avg Delivery Latency by Channel",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(notification_delivery_duration_seconds_sum{channel=~\"$channel\"}[1m])) by (channel) / sum(rate(notification_delivery_duration_seconds_count{channel=~\"$channel\"}[1m])) by (channel)",
          "legendFormat": "avg \u2014 {{channel}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "Resilience",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "collapsed": false
    },
    {
      "title": "Rate Limit Hits over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(rate_limit_hits_total[1m])",
          "legendFormat": "{{instance}} rate limit hits/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          },
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "title": "Circuit Breaker Opens over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(circuit_breaker_open_total[1m])",
          "legendFormat": "{{instance}} CB opens/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          },
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "title": "Total Delivered vs Failed (cumulative)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(notifications_delivered_total{channel=~\"$channel\"}) by (channel)",
          "legendFormat": "delivered \u2014 {{channel}}"
        },
        {
          "expr": "sum(notifications_failed_total{channel=~\"$channel\"}) by (channel)",
          "legendFormat": "failed \u2014 {{channel}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          }
        }
      }
    }
  ]
}

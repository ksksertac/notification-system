{
  "title": "Log Explorer",
  "uid": "log-explorer",
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(container)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 1
      },
      {
        "name": "level",
        "type": "custom",
        "query": "info,warn,error,debug",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": [
          {
            "text": "info",
            "value": "info",
            "selected": false
          },
          {
            "text": "warn",
            "value": "warn",
            "selected": false
          },
          {
            "text": "error",
            "value": "error",
            "selected": false
          },
          {
            "text": "debug",
            "value": "debug",
            "selected": false
          }
        ]
      },
      {
        "name": "search",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "label": "Search Text"
      }
    ]
  },
  "panels": [
    {
      "title": "Log Volume",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$container\"} | json | level=~\"$level\" |~ \"$search\" [1m])) by (level)",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1,
            "drawStyle": "bars",
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warn"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "debug"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$container\"} | json | level=~\"$level\" |~ \"$search\" [1m])) by (container)",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "drawStyle": "bars",
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "title": "Error Logs",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "collapsed": false
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$container\"} | json | level=\"error\" [1m])) by (container)",
          "legendFormat": "{{container}} errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 25,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "title": "Log Streams",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "collapsed": false
    },
    {
      "title": "notification-api Logs",
      "type": "logs",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{container=~\".*notification-api.*\"} | json | level=~\"$level\" |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "notification-consumer Logs",
      "type": "logs",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{container=~\".*notification-consumer.*\"} | json | level=~\"$level\" |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "notification-scheduler Logs",
      "type": "logs",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 45
      },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{container=~\".*notification-scheduler.*\"} | json | level=~\"$level\" |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "notification-dbwriter Logs",
      "type": "logs",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 57
      },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{container=~\".*notification-dbwriter.*\"} | json | level=~\"$level\" |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
